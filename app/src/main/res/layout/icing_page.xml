<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <ImageView
        android:id="@+id/backBtn"
        android:layout_width="46dp"
        android:layout_height="41dp"
        android:layout_marginStart="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.053"
        tools:srcCompat="@drawable/ic_launcher_background"
        />

    <ImageView
        android:id="@+id/logo"
        android:layout_width="91dp"
        android:layout_height="43dp"
        android:layout_marginEnd="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.053"
        tools:srcCompat="@drawable/ic_launcher_background" />

    <ImageView
        android:id="@+id/icingHead"
        android:layout_width="149dp"
        android:layout_height="64dp"
        android:layout_marginTop="52dp"
        app:layout_constraintEnd_toStartOf="@+id/logo"
        app:layout_constraintHorizontal_bias="0.609"
        app:layout_constraintStart_toEndOf="@+id/backBtn"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@drawable/ic_launcher_background" />

    <ImageView
        android:id="@+id/IPreview1"
        android:layout_width="219dp"
        android:layout_height="119dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/icingHead"
        tools:srcCompat="@drawable/ic_launcher_background"
        android:visibility="gone"/>

    <ImageView
        android:id="@+id/IPreview2"
        android:layout_width="219dp"
        android:layout_height="119dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/icingHead"
        tools:srcCompat="@drawable/ic_launcher_background"
        android:visibility="gone"/>

    <ImageView
        android:id="@+id/IPreview3"
        android:layout_width="219dp"
        android:layout_height="119dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/icingHead"
        tools:srcCompat="@drawable/ic_launcher_background"
        android:visibility="gone"/>

    <ImageView
        android:id="@+id/IPreview4"
        android:layout_width="219dp"
        android:layout_height="119dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/icingHead"
        tools:srcCompat="@drawable/ic_launcher_background"
        android:visibility="gone"/>

    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="354dp"
        android:layout_height="372dp"
        android:background="@drawable/backgroundcolor2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/icingHead"
        app:layout_constraintVertical_bias="0.679">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/CchocoGanache"
                    android:layout_width="139dp"
                    android:layout_height="197dp"
                    android:layout_marginStart="23dp"
                    android:src="@drawable/ic_launcher_background"
                    android:visibility="gone"
                    app:srcCompat="@drawable/cchocoganache"
                    tools:srcCompat="@drawable/cchocoganache" />

                <ImageView
                    android:id="@+id/chocoGanache"
                    android:layout_width="139dp"
                    android:layout_height="197dp"
                    android:layout_marginStart="23dp"
                    android:src="@drawable/ic_launcher_background"
                    app:srcCompat="@drawable/chocoganache"
                    tools:srcCompat="@drawable/chocoganache" />

                <ImageView
                    android:id="@+id/CbutterCream"
                    android:layout_width="139dp"
                    android:layout_height="197dp"
                    android:layout_marginStart="30dp"
                    android:src="@drawable/ic_launcher_background"
                    android:visibility="gone"
                    app:srcCompat="@drawable/cbuttercream"
                    tools:srcCompat="@drawable/cbuttercream" />

                <ImageView
                    android:id="@+id/butterCream"
                    android:layout_width="139dp"
                    android:layout_height="197dp"
                    android:layout_marginStart="30dp"
                    android:src="@drawable/ic_launcher_background"
                    app:srcCompat="@drawable/buttercream"
                    tools:srcCompat="@drawable/buttercream" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/CcreamCheese"
                    android:layout_width="139dp"
                    android:layout_height="197dp"
                    android:layout_marginStart="23dp"
                    android:src="@drawable/ic_launcher_background"
                    android:visibility="gone"
                    app:srcCompat="@drawable/ccreamcheese"
                    tools:srcCompat="@drawable/ccreamcheese" />

                <ImageView
                    android:id="@+id/creamCheese"
                    android:layout_width="139dp"
                    android:layout_height="197dp"
                    android:layout_marginStart="23dp"
                    android:src="@drawable/ic_launcher_background"
                    app:srcCompat="@drawable/creamcheese"
                    tools:srcCompat="@drawable/creamcheese" />

                <ImageView
                    android:id="@+id/Cube"
                    android:layout_width="139dp"
                    android:layout_height="197dp"
                    android:layout_marginStart="30dp"
                    android:src="@drawable/ic_launcher_background"
                    android:visibility="gone"
                    app:srcCompat="@drawable/cube"
                    tools:srcCompat="@drawable/cube" />

                <ImageView
                    android:id="@+id/ube"
                    android:layout_width="139dp"
                    android:layout_height="197dp"
                    android:layout_marginStart="30dp"
                    android:src="@drawable/ic_launcher_background"
                    app:srcCompat="@drawable/ube"
                    tools:srcCompat="@drawable/ube" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:text="TextView"
        android:textSize="30dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scrollView2"
        app:layout_constraintVertical_bias="0.309" />

    <ImageView
        android:id="@+id/nextBtn"
        android:layout_width="114dp"
        android:layout_height="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.9"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scrollView2"
        app:layout_constraintVertical_bias="0.7"
        app:srcCompat="@drawable/next"
        tools:srcCompat="@drawable/next" />


</androidx.constraintlayout.widget.ConstraintLayout>